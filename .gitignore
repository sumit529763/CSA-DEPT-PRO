# ══════════════════════════════════════════════════════════
#  CSA-DEPT-PRO  —  .gitignore
#  Monorepo: client (Vite + React) + server (Node/Express)
# ══════════════════════════════════════════════════════════


# ── Dependencies ──────────────────────────────────────────
node_modules/
client/node_modules/
server/node_modules/
package-lock.json
client/package-lock.json
server/package-lock.json
yarn.lock
pnpm-lock.yaml


# ── Build outputs ─────────────────────────────────────────
dist/
dist-ssr/
build/
client/dist/
client/build/
*.local


# ── Vite cache ────────────────────────────────────────────
.vite/
client/.vite/


# ════════════════════════════════════════════════════════════
#  ENVIRONMENT FILES  —  NEVER commit any .env file
#  These contain: MongoDB URI, JWT secret, Cloudinary keys,
#  Firebase config, and other sensitive credentials.
# ════════════════════════════════════════════════════════════
.env
.env.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.staging
.env.staging.local
.env.test
.env.test.local
.env.*

# client-level env files
client/.env
client/.env.local
client/.env.development
client/.env.development.local
client/.env.production
client/.env.production.local
client/.env.staging
client/.env.staging.local
client/.env.test
client/.env.test.local
client/.env.*

# server-level env files
server/.env
server/.env.local
server/.env.development
server/.env.development.local
server/.env.production
server/.env.production.local
server/.env.staging
server/.env.staging.local
server/.env.test
server/.env.test.local
server/.env.*


# ── Firebase ──────────────────────────────────────────────
.firebase/
client/.firebase/
firebase-debug.log
firebase-debug.*.log
ui-debug.log
.firebaserc


# ── Logs ──────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
server/logs/
server/src/logs/


# ── Server — temp/local uploads ───────────────────────────
# Multer writes temp files to disk before Cloudinary upload
server/uploads/
server/tmp/
uploads/
tmp/


# ── Editor / IDE ──────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo


# ── OS generated files ────────────────────────────────────
.DS_Store           # macOS
Thumbs.db           # Windows
ehthumbs.db         # Windows
Desktop.ini         # Windows


# ── Testing / Coverage ────────────────────────────────────
coverage/
client/coverage/
server/coverage/
.nyc_output/


# ── Misc tooling cache ────────────────────────────────────
.cache/
.cache-loader/
*.tgz
.parcel-cache/